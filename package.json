{
  "name": "next-realworld-fullstack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate:all && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\"",
    "migrate": "prisma migrate dev",
    "studio": "prisma studio",
    "seed": "prisma db seed",
    "postinstall": "prisma generate",
    "api:docs": "npx swagger-ui-watcher specs/openapi.yaml",
    "spec:lint": "spectral lint specs/openapi.yaml",
    "spec:validate": "npx @redocly/cli lint specs/openapi.yaml",
    "generate:types": "openapi-typescript specs/openapi.yaml -o generated/types/api.d.ts",
    "generate:client": "openapi-typescript-codegen --input specs/openapi.yaml --output generated/api-client --client fetch",
    "generate:zod": "node scripts/generate-zod.js",
    "generate:tests": "node scripts/generate-tests.js",
    "generate:all": "npm run spec:validate && npm run generate:types && npm run generate:client && npm run generate:zod",
    "mock:server": "prism mock specs/openapi.yaml",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:contract": "jest tests/contract"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.6.0",
    "@types/bcrypt": "^5.0.2",
    "@vercel/postgres": "^0.5.1",
    "bcrypt": "^5.1.1",
    "clsx": "^2.0.0",
    "marked": "^11.0.0",
    "next": "14.0.3",
    "next-auth": "^4.24.5",
    "next-intl": "^3.4.1",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.33.1",
    "slug": "^8.2.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.7.0",
    "@playwright/test": "^1.58.2",
    "@redocly/cli": "^1.10.0",
    "@stoplight/prism-cli": "^5.5.0",
    "@stoplight/spectral-cli": "^6.11.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/slug": "^5.0.7",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.3",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.0",
    "openapi-typescript": "^6.7.0",
    "openapi-typescript-codegen": "^0.27.0",
    "postcss": "^8",
    "prettier": "^3.1.0",
    "prisma": "^5.6.0",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
